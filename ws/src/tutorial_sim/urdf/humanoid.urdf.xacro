<?xml version="1.0"?>
<!--
  A toy humanoid URDF for the tutorial. Six joints, all revolute:
    left_shoulder_pitch, left_elbow,
    right_shoulder_pitch, right_elbow,
    left_hip_pitch, right_hip_pitch.
  This is NOT the G1's real kinematics — it's the *shape* of a URDF
  reduced to the smallest form that still teaches TF + robot_state_publisher.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tutor_humanoid">

  <!-- materials -->
  <material name="body_blue"><color rgba="0.20 0.45 0.85 1.0"/></material>
  <material name="head_grey"><color rgba="0.85 0.85 0.85 1.0"/></material>
  <material name="limb_orange"><color rgba="0.95 0.55 0.10 1.0"/></material>
  <material name="joint_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>

  <!-- shorthand for a single revolute joint -->
  <xacro:macro name="rev_joint" params="name parent child xyz axis lower upper">
    <joint name="${name}" type="revolute">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <axis xyz="${axis}"/>
      <limit effort="50" velocity="2.0" lower="${lower}" upper="${upper}"/>
    </joint>
  </xacro:macro>

  <!-- ============================================================ TORSO -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry><box size="0.28 0.16 0.40"/></geometry>
      <material name="body_blue"/>
    </visual>
  </link>

  <!-- ============================================================ HEAD -->
  <link name="head_link">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><sphere radius="0.10"/></geometry>
      <material name="head_grey"/>
    </visual>
  </link>
  <joint name="neck" type="fixed">
    <parent link="base_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 0.45" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ ARMS -->
  <xacro:macro name="arm" params="side reflect">
    <!-- shoulder ball -->
    <link name="${side}_shoulder_link">
      <visual>
        <geometry><sphere radius="0.04"/></geometry>
        <material name="joint_dark"/>
      </visual>
    </link>

    <!-- upper arm -->
    <link name="${side}_upper_arm_link">
      <visual>
        <origin xyz="0 0 -0.13" rpy="0 0 0"/>
        <geometry><cylinder radius="0.035" length="0.26"/></geometry>
        <material name="limb_orange"/>
      </visual>
    </link>

    <!-- elbow ball -->
    <link name="${side}_elbow_link">
      <visual>
        <geometry><sphere radius="0.035"/></geometry>
        <material name="joint_dark"/>
      </visual>
    </link>

    <!-- forearm -->
    <link name="${side}_forearm_link">
      <visual>
        <origin xyz="0 0 -0.12" rpy="0 0 0"/>
        <geometry><cylinder radius="0.030" length="0.24"/></geometry>
        <material name="limb_orange"/>
      </visual>
    </link>

    <!-- joints -->
    <xacro:rev_joint name="${side}_shoulder_pitch"
                     parent="base_link" child="${side}_shoulder_link"
                     xyz="0 ${0.10 * reflect} 0.38"
                     axis="0 1 0" lower="-2.0" upper="2.0"/>

    <joint name="${side}_shoulder_link_to_upper" type="fixed">
      <parent link="${side}_shoulder_link"/>
      <child link="${side}_upper_arm_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <xacro:rev_joint name="${side}_elbow"
                     parent="${side}_upper_arm_link"
                     child="${side}_elbow_link"
                     xyz="0 0 -0.26"
                     axis="0 1 0" lower="0" upper="2.4"/>

    <joint name="${side}_elbow_link_to_forearm" type="fixed">
      <parent link="${side}_elbow_link"/>
      <child link="${side}_forearm_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:arm side="left"  reflect="1"/>
  <xacro:arm side="right" reflect="-1"/>

  <!-- ============================================================ LEGS -->
  <xacro:macro name="leg" params="side reflect">
    <link name="${side}_hip_link">
      <visual>
        <geometry><sphere radius="0.045"/></geometry>
        <material name="joint_dark"/>
      </visual>
    </link>
    <link name="${side}_thigh_link">
      <visual>
        <origin xyz="0 0 -0.18" rpy="0 0 0"/>
        <geometry><cylinder radius="0.05" length="0.36"/></geometry>
        <material name="limb_orange"/>
      </visual>
    </link>

    <xacro:rev_joint name="${side}_hip_pitch"
                     parent="base_link" child="${side}_hip_link"
                     xyz="0 ${0.06 * reflect} 0"
                     axis="0 1 0" lower="-1.5" upper="1.5"/>
    <joint name="${side}_hip_link_to_thigh" type="fixed">
      <parent link="${side}_hip_link"/>
      <child link="${side}_thigh_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:leg side="left"  reflect="1"/>
  <xacro:leg side="right" reflect="-1"/>

</robot>

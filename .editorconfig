root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,html,yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{cmake,CMakeLists.txt}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

# Generated / vendored — leave whitespace alone.
[ws/src/g1_description/**]
trim_trailing_whitespace = false
insert_final_newline = false
